# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# ── Resend (email) ────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ── App URLs ──────────────────────────────────────────────
# Your deployed frontend (Vercel). Used in email links and CORS.
FRONTEND_URL=https://your-app.vercel.app

# Your backend URL (Render). Used in confirmation email links.
BACKEND_URL=https://your-backend.onrender.com

# ── Security ──────────────────────────────────────────────
# Protect admin endpoints — generate with: openssl rand -hex 32
ADMIN_SECRET=your_strong_random_secret_here

# Your email — get alerted when scrapers break
OWNER_EMAIL=you@youremail.com

# ── Scraper config ────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
MAX_PAGES_PER_SOURCE=10
REQUEST_DELAY_SECONDS=2
scraper_alert_threshold=0

# ── Monetization (optional) ───────────────────────────────
# Sponsor slot in digest emails — rotate these per campaign
# DIGEST_SPONSOR=Kickresume
# DIGEST_SPONSOR_URL=https://kickresume.com?ref=internasia
# DIGEST_SPONSOR_COPY=Build an ATS-beating CV in minutes

# Enable Swagger docs (only for local dev)
# DOCS_ENABLED=true
